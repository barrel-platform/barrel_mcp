{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    {cowboy, "2.10.0"},
    {hackney, "1.20.1"}
]}.

{shell, [{apps, [barrel_mcp]}]}.

{eunit_opts, [verbose]}.
{cover_enabled, true}.

{dialyzer, [
    {warnings, [unmatched_returns, error_handling, unknown]},
    {plt_extra_apps, [cowboy, hackney]}
]}.

{profiles, [
    {test, [
        {deps, [{meck, "0.9.2"}]}
    ]}
]}.

%% Documentation
{project_plugins, [rebar3_ex_doc]}.

{ex_doc, [
    {extras, [
        {"README.md", #{title => "Overview"}},
        {"guides/getting-started.md", #{title => "Getting Started"}},
        {"guides/stdio.md", #{title => "stdio Transport"}},
        {"guides/authentication.md", #{title => "Authentication"}},
        {"guides/tools-resources-prompts.md", #{title => "Tools, Resources & Prompts"}},
        {"guides/client.md", #{title => "MCP Client"}},
        {"LICENSE", #{title => "License"}}
    ]},
    {main, "README.md"},
    {homepage_url, "https://github.com/barrel-db/barrel_mcp"},
    {source_url, "https://github.com/barrel-db/barrel_mcp"},
    {api_reference, true},
    {groups_for_modules, [
        {"Main API", [barrel_mcp]},
        {"Authentication", [barrel_mcp_auth, barrel_mcp_auth_none,
                           barrel_mcp_auth_bearer, barrel_mcp_auth_apikey,
                           barrel_mcp_auth_basic]},
        {"Server", [barrel_mcp_http, barrel_mcp_stdio, barrel_mcp_protocol]},
        {"Client", [barrel_mcp_client]},
        {"Registry", [barrel_mcp_registry]}
    ]}
]}.

{hex, [{doc, ex_doc}]}.
